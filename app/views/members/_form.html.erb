<%= form_with(model: member, class: "space-y-5") do |f| %>
  <% if member.errors.any? %>
    <div class="bg-rose-500/10 border border-rose-500/20 text-rose-400 text-sm px-4 py-3 rounded-xl">
      <% member.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <label class="block text-xs font-semibold text-[#8896b3] uppercase tracking-wider mb-2">이름</label>
    <%= f.text_field :name, required: true, autofocus: true, placeholder: "예: 김철수",
        class: "w-full h-12 px-4 bg-[#111a2e] border border-[#1e2d4a] rounded-xl text-white placeholder-[#5d6d8e] focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors" %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit member.new_record? ? "추가" : "수정 완료",
        class: "flex-1 h-12 bg-gradient-to-r from-indigo-500 to-violet-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-500/25 active:scale-[0.98] transition-all cursor-pointer" %>
    <a href="<%= members_path %>" class="h-12 px-5 flex items-center justify-center text-sm font-semibold text-[#8896b3] hover:text-[#c5cfe0] border border-[#1e2d4a] rounded-xl transition-colors">
      취소
    </a>
  </div>
<% end %>
