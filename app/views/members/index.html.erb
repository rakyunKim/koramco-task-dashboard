<div class="animate-fade-in-up">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl lg:text-2xl font-extrabold text-white">멤버 관리</h1>
    <a href="<%= new_member_path %>" class="inline-flex items-center gap-1.5 px-4 h-10 bg-gradient-to-r from-indigo-500 to-violet-500 text-white text-sm font-bold rounded-xl shadow-lg shadow-indigo-500/20 active:scale-[0.98] transition-all">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      추가
    </a>
  </div>

  <% if @members.any? %>
    <div class="space-y-3 lg:grid lg:grid-cols-2 xl:grid-cols-3 lg:gap-4 lg:space-y-0">
      <% @members.each_with_index do |member, i| %>
        <div class="card p-4 flex items-center justify-between animate-fade-in-up stagger-<%= [i + 1, 5].min %>">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center shrink-0">
              <span class="text-sm font-bold text-white"><%= member.name.first %></span>
            </div>
            <div>
              <p class="font-bold text-[15px] text-white"><%= member.name %></p>
              <p class="text-[13px] text-[#8896b3] font-medium">
                이번 주 작업 <%= member.total_tasks_count %>건
                <% if member.total_tasks_count > 0 %>
                  / 완료 <span class="text-emerald-400 font-semibold"><%= member.completed_tasks_count %>건</span>
                <% end %>
              </p>
            </div>
          </div>
          <div class="flex items-center gap-0.5">
            <a href="<%= edit_member_path(member) %>" class="text-[#5d6d8e] hover:text-[#8896b3] transition-colors p-2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
              </svg>
            </a>
            <%= button_to member_path(member), method: :delete,
                class: "text-[#5d6d8e] hover:text-rose-400 transition-colors p-2",
                data: { turbo_confirm: "#{member.name}님을 삭제하시겠습니까? 연결된 모든 작업도 삭제됩니다." } do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
              </svg>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card border-dashed p-8 text-center lg:max-w-md lg:mx-auto">
      <div class="w-14 h-14 rounded-full bg-[#172035] flex items-center justify-center mx-auto mb-4">
        <svg class="w-7 h-7 text-[#5d6d8e]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
        </svg>
      </div>
      <p class="text-sm text-[#8896b3] mb-4">아직 등록된 멤버가 없습니다</p>
      <a href="<%= new_member_path %>" class="inline-flex items-center gap-1.5 text-sm font-semibold text-indigo-400 hover:text-indigo-300 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        첫 멤버 추가
      </a>
    </div>
  <% end %>
</div>
