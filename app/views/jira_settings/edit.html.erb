<% content_for(:title) { "Jira 설정" } %>

<div class="space-y-6">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-xl font-extrabold text-[#1a202c]">Jira 연동 설정</h1>
      <p class="text-sm text-[#64748b] mt-1">Jira Cloud와 연동하여 티켓을 동기화합니다.</p>
    </div>
    <a href="<%= root_path %>" class="text-sm font-semibold text-[#64748b] hover:text-[#334155] transition-colors">
      돌아가기
    </a>
  </div>

  <!-- Connection Status -->
  <div class="bg-white rounded-2xl border border-[#e2e6ed] p-5">
    <div class="flex items-center gap-3">
      <% if JiraSetting.configured? %>
        <div class="w-3 h-3 rounded-full bg-emerald-400"></div>
        <span class="text-sm font-semibold text-emerald-600">연결됨</span>
        <span class="text-sm text-[#94a3b8]"><%= JiraSetting.current.site_url %></span>
      <% else %>
        <div class="w-3 h-3 rounded-full bg-[#94a3b8]"></div>
        <span class="text-sm font-semibold text-[#64748b]">미연결</span>
      <% end %>
    </div>
  </div>

  <!-- Settings Form -->
  <div class="bg-white rounded-2xl border border-[#e2e6ed] p-5">
    <%= form_with(model: @jira_setting, url: jira_setting_path, method: :patch, class: "space-y-5") do |f| %>
      <% if @jira_setting.errors.any? %>
        <div class="bg-rose-50 border border-rose-200 text-rose-600 text-sm px-4 py-3 rounded-xl">
          <% @jira_setting.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div>
        <label class="block text-xs font-semibold text-[#64748b] uppercase tracking-wider mb-2">Site URL</label>
        <%= f.text_field :site_url, placeholder: "https://myteam.atlassian.net",
            class: "w-full h-12 px-4 bg-white border border-[#e2e6ed] rounded-xl text-[#1a202c] placeholder-[#94a3b8] focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors" %>
      </div>

      <div>
        <label class="block text-xs font-semibold text-[#64748b] uppercase tracking-wider mb-2">Email</label>
        <%= f.email_field :email, placeholder: "user@example.com",
            class: "w-full h-12 px-4 bg-white border border-[#e2e6ed] rounded-xl text-[#1a202c] placeholder-[#94a3b8] focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors" %>
      </div>

      <div>
        <label class="block text-xs font-semibold text-[#64748b] uppercase tracking-wider mb-2">API Token</label>
        <%= f.password_field :api_token, placeholder: @jira_setting.persisted? ? "변경하려면 입력" : "Jira API Token",
            class: "w-full h-12 px-4 bg-white border border-[#e2e6ed] rounded-xl text-[#1a202c] placeholder-[#94a3b8] focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors" %>
        <p class="text-xs text-[#94a3b8] mt-1.5">
          Atlassian 계정 설정에서 API Token을 생성하세요.
        </p>
      </div>

      <div class="flex gap-3 pt-2">
        <%= f.submit "저장", class: "flex-1 h-12 bg-gradient-to-r from-indigo-500 to-violet-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-500/25 active:scale-[0.98] transition-all cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <!-- Actions -->
  <% if JiraSetting.configured? %>
    <div class="bg-white rounded-2xl border border-[#e2e6ed] p-5 space-y-3">
      <h3 class="text-sm font-bold text-[#1a202c]">연동 관리</h3>
      <div class="flex gap-3">
        <%= button_to "연결 테스트", test_connection_jira_setting_path, method: :post,
            class: "h-10 px-5 text-sm font-semibold text-indigo-600 border border-indigo-200 bg-indigo-50 rounded-xl hover:bg-indigo-100 transition-colors cursor-pointer" %>
        <%= button_to "연결 해제", jira_setting_path, method: :delete,
            data: { turbo_confirm: "Jira 연동을 해제하시겠습니까?" },
            class: "h-10 px-5 text-sm font-semibold text-rose-600 border border-rose-200 bg-rose-50 rounded-xl hover:bg-rose-100 transition-colors cursor-pointer" %>
      </div>
    </div>
  <% end %>
</div>
