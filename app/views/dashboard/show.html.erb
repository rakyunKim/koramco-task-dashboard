<% if @wig %>
  <div class="space-y-6 lg:space-y-8">
    <!-- WIG Card -->
    <%= render partial: "wigs/card", locals: { wig: @wig } %>

    <!-- Desktop: 2-Column / Mobile: Stack -->
    <div class="lg:grid lg:grid-cols-2 lg:gap-8 xl:gap-10">

      <!-- Lead Measures -->
      <section class="animate-fade-in-up stagger-1 mb-8 lg:mb-0">
        <div class="flex items-center justify-between mb-4">
          <h2 class="section-header">이번 주 선행지표</h2>
          <a href="<%= new_wig_lead_measure_path(@wig) %>" class="text-[13px] font-semibold text-indigo-400 hover:text-indigo-300 transition-colors flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            추가
          </a>
        </div>

        <% if @lead_measures.present? %>
          <div class="space-y-3">
            <% @lead_measures.each do |lm| %>
              <%= render partial: "lead_measures/card", locals: { lead_measure: lm } %>
            <% end %>
          </div>
        <% else %>
          <div class="card border-dashed p-6 text-center">
            <p class="text-sm text-[#5d6d8e]">선행지표를 추가하세요</p>
            <a href="<%= new_wig_lead_measure_path(@wig) %>" class="inline-flex items-center gap-1.5 text-sm font-semibold text-indigo-400 hover:text-indigo-300 mt-2.5 transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
              첫 선행지표 추가
            </a>
          </div>
        <% end %>
      </section>

      <!-- Tasks by Member -->
      <section class="animate-fade-in-up stagger-2">
        <div class="flex items-center justify-between mb-4">
          <h2 class="section-header">이번 주 작업</h2>
          <% if @lead_measures.present? %>
            <a href="<%= new_lead_measure_task_path(@lead_measures.first) %>" class="text-[13px] font-semibold text-indigo-400 hover:text-indigo-300 transition-colors flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
              추가
            </a>
          <% end %>
        </div>

        <% if @tasks_by_member.present? %>
          <div class="space-y-4">
            <% @tasks_by_member.each do |member, tasks| %>
              <div class="card overflow-hidden">
                <!-- Member Header -->
                <div class="px-4 py-3 bg-[#172035]/60 border-b border-[#1e2d4a]/60 flex items-center justify-between">
                  <div class="flex items-center gap-2.5">
                    <div class="w-7 h-7 rounded-full bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center">
                      <span class="text-[11px] font-bold text-white"><%= member.name.first %></span>
                    </div>
                    <span class="text-[15px] font-bold text-white"><%= member.name %></span>
                  </div>
                  <div class="flex items-center gap-3">
                    <a href="<%= import_tasks_path(member_id: member.id) %>"
                       data-turbo-frame="modal"
                       class="text-[#5d6d8e] hover:text-indigo-400 transition-colors p-1"
                       title="이전 작업 가져오기">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
                      </svg>
                    </a>
                    <% done = tasks.count(&:completed?) %>
                    <% total = tasks.size %>
                    <span class="text-[13px] font-bold tabular-nums <%= done == total && total > 0 ? 'text-emerald-400' : 'text-[#8896b3]' %>">
                      <%= done %>/<%= total %>
                    </span>
                  </div>
                </div>
                <!-- Tasks -->
                <div class="px-4 divide-y divide-[#1e2d4a]/50">
                  <% tasks.each do |task| %>
                    <%= render partial: "tasks/task", locals: { task: task } %>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="card border-dashed p-6 text-center">
            <p class="text-sm text-[#5d6d8e]">아직 등록된 작업이 없습니다</p>
            <% if @members.empty? %>
              <a href="<%= new_member_path %>" class="inline-flex items-center gap-1.5 text-sm font-semibold text-indigo-400 hover:text-indigo-300 mt-2.5 transition-colors">
                먼저 멤버를 추가하세요
              </a>
            <% elsif @lead_measures.present? %>
              <a href="<%= new_lead_measure_task_path(@lead_measures.first) %>" class="inline-flex items-center gap-1.5 text-sm font-semibold text-indigo-400 hover:text-indigo-300 mt-2.5 transition-colors">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                첫 작업 추가
              </a>
            <% end %>
          </div>
        <% end %>
      </section>
    </div>

  </div>

<% else %>
  <!-- Empty State -->
  <div class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center animate-fade-in-up">
      <div class="w-20 h-20 rounded-2xl bg-[#111a2e] border border-[#1e2d4a] flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-[#5d6d8e]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
        </svg>
      </div>
      <h2 class="text-xl font-extrabold mb-2 text-white">목표를 설정하세요</h2>
      <p class="text-sm text-[#8896b3] mb-6 leading-relaxed">가장 중요한 목표(WIG)를 설정하고<br>팀의 진행 상황을 추적하세요</p>
      <a href="<%= new_wig_path %>" class="inline-flex items-center gap-2 px-6 h-12 bg-gradient-to-r from-indigo-500 to-violet-500 text-white font-bold rounded-xl shadow-lg shadow-indigo-500/20 hover:shadow-indigo-500/30 active:scale-[0.98] transition-all">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        WIG 설정하기
      </a>
    </div>
  </div>
<% end %>
