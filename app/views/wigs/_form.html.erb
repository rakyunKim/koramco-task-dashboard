<%= form_with(model: wig, url: wig.new_record? ? wigs_path : wig_path(wig), class: "space-y-5") do |f| %>
  <% if wig.errors.any? %>
    <div class="bg-rose-500/10 border border-rose-500/20 text-rose-400 text-sm px-4 py-3 rounded-xl">
      <% wig.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <label class="block text-xs font-semibold text-[#8896b3] uppercase tracking-wider mb-2">목표 제목</label>
    <%= f.text_field :title, required: true, placeholder: "예: 월 매출 5억 달성",
        class: "w-full h-12 px-4 bg-[#111a2e] border border-[#1e2d4a] rounded-xl text-white placeholder-[#5d6d8e] focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors" %>
  </div>

  <div>
    <label class="block text-xs font-semibold text-[#8896b3] uppercase tracking-wider mb-2">설명 (선택)</label>
    <%= f.text_area :description, rows: 2, placeholder: "목표에 대한 간단한 설명",
        class: "w-full px-4 py-3 bg-[#111a2e] border border-[#1e2d4a] rounded-xl text-white placeholder-[#5d6d8e] focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors resize-none" %>
  </div>

  <%= f.hidden_field :target_value, value: wig.target_value || 1 %>

  <div>
    <label class="block text-xs font-semibold text-[#8896b3] uppercase tracking-wider mb-2">마감일 (선택)</label>
    <%= f.date_field :deadline,
        class: "w-full h-12 px-4 bg-[#111a2e] border border-[#1e2d4a] rounded-xl text-white focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors" %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit wig.new_record? ? "WIG 설정" : "수정 완료",
        class: "flex-1 h-12 bg-gradient-to-r from-indigo-500 to-violet-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-500/25 active:scale-[0.98] transition-all cursor-pointer" %>
    <a href="<%= root_path %>" class="h-12 px-5 flex items-center justify-center text-sm font-semibold text-[#8896b3] hover:text-[#c5cfe0] border border-[#1e2d4a] rounded-xl transition-colors">
      취소
    </a>
  </div>
<% end %>
