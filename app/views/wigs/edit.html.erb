<div class="animate-fade-in-up lg:max-w-lg lg:mx-auto">
  <h1 class="text-xl lg:text-2xl font-extrabold mb-6">WIG 수정</h1>
  <%= render "form", wig: @wig %>

  <div class="mt-6 pt-6 border-t border-slate-800/40">
    <%= button_to wig_path(@wig), method: :delete,
        class: "text-sm text-rose-500 hover:text-rose-400 font-semibold transition-colors",
        data: { turbo_confirm: "정말 삭제하시겠습니까? 연결된 모든 선행지표와 작업도 삭제됩니다." } do %>
      WIG 삭제
    <% end %>
  </div>
</div>
