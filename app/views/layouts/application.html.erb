<!DOCTYPE html>
<html lang="ko" class="h-full">
  <head>
    <title><%= content_for(:title) || "Scoreboard" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#f5f7fa">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=DM+Serif+Display&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      * { font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif; }
      .font-display { font-family: 'DM Serif Display', Georgia, serif; }
    </style>
  </head>

  <body class="h-full bg-[#f5f7fa] text-[#1a202c] antialiased">
    <% if session[:authenticated] %>
      <!-- ═══ HEADER (all screens) ═══ -->
      <header class="sticky top-0 z-50 backdrop-blur-xl bg-white/90 border-b border-[#e2e6ed]" style="padding-top: env(safe-area-inset-top, 0px);">
        <div class="max-w-lg lg:max-w-6xl mx-auto px-4 lg:px-8 h-14 flex items-center justify-between">
          <!-- Left: Logo + Nav -->
          <div class="flex items-center gap-6">
            <a href="<%= root_path %>" class="flex items-center gap-2.5">
              <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
                </svg>
              </div>
              <span class="font-extrabold text-[15px] tracking-tight hidden sm:inline">Scoreboard</span>
            </a>
            <!-- Desktop nav links -->
            <nav class="hidden lg:flex items-center gap-1">
              <a href="<%= root_path %>"
                 class="px-3 py-1.5 rounded-lg text-[13px] font-semibold transition-all
                        <%= controller_name == 'dashboard' ? 'bg-indigo-50 text-indigo-600' : 'text-[#64748b] hover:text-[#334155] hover:bg-[#f0f2f5]' %>">
                대시보드
              </a>
              <a href="<%= members_path %>"
                 class="px-3 py-1.5 rounded-lg text-[13px] font-semibold transition-all
                        <%= controller_name == 'members' ? 'bg-indigo-50 text-indigo-600' : 'text-[#64748b] hover:text-[#334155] hover:bg-[#f0f2f5]' %>">
                멤버
              </a>
              <a href="<%= edit_jira_setting_path %>"
                 class="px-3 py-1.5 rounded-lg text-[13px] font-semibold transition-all
                        <%= controller_name == 'jira_settings' ? 'bg-indigo-50 text-indigo-600' : 'text-[#64748b] hover:text-[#334155] hover:bg-[#f0f2f5]' %>">
                설정
              </a>
            </nav>
          </div>
          <!-- Right: Logout -->
          <%= button_to logout_path, method: :delete, class: "text-[#94a3b8] hover:text-[#64748b] transition-colors p-2 -mr-2", data: { turbo_confirm: "로그아웃 하시겠습니까?" } do %>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9" />
            </svg>
          <% end %>
        </div>
      </header>
    <% end %>

    <!-- ═══ FLASH MESSAGES ═══ -->
    <% if flash[:notice] %>
      <div class="max-w-lg lg:max-w-6xl mx-auto w-full px-4 lg:px-8 pt-3">
        <div class="bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm font-medium px-4 py-3 rounded-xl animate-fade-in-up">
          <%= flash[:notice] %>
        </div>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="max-w-lg lg:max-w-6xl mx-auto w-full px-4 lg:px-8 pt-3">
        <div class="bg-rose-50 border border-rose-200 text-rose-700 text-sm font-medium px-4 py-3 rounded-xl animate-fade-in-up">
          <%= flash[:alert] %>
        </div>
      </div>
    <% end %>

    <!-- ═══ MAIN CONTENT ═══ -->
    <main class="pb-28 lg:pb-8">
      <div class="max-w-lg lg:max-w-6xl mx-auto w-full px-4 lg:px-8 py-5 lg:py-8">
        <%= yield %>
      </div>
    </main>

    <% if session[:authenticated] %>
      <!-- ═══ MOBILE BOTTOM NAV (< lg) ═══ -->
      <nav class="lg:hidden fixed bottom-0 left-0 right-0 z-[100] bg-white border-t border-[#e2e6ed]" style="padding-bottom: env(safe-area-inset-bottom, 0px);">
        <div class="max-w-lg mx-auto flex">
          <a href="<%= root_path %>"
             data-active="<%= controller_name == 'dashboard' %>"
             class="bottom-nav-item">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="<%= controller_name == 'dashboard' ? '2' : '1.5' %>">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
            </svg>
            <span>대시보드</span>
          </a>
          <a href="<%= members_path %>"
             data-active="<%= controller_name == 'members' %>"
             class="bottom-nav-item">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="<%= controller_name == 'members' ? '2' : '1.5' %>">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
            </svg>
            <span>멤버</span>
          </a>
          <a href="<%= edit_jira_setting_path %>"
             data-active="<%= controller_name == 'jira_settings' %>"
             class="bottom-nav-item">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="<%= controller_name == 'jira_settings' ? '2' : '1.5' %>">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.343 3.94c.09-.542.56-.94 1.11-.94h1.093c.55 0 1.02.398 1.11.94l.149.894c.07.424.384.764.78.93.398.164.855.142 1.205-.108l.737-.527a1.125 1.125 0 011.45.12l.773.774c.39.389.44 1.002.12 1.45l-.527.737c-.25.35-.272.806-.107 1.204.165.397.505.71.93.78l.893.15c.543.09.94.56.94 1.109v1.094c0 .55-.397 1.02-.94 1.11l-.893.149c-.425.07-.765.383-.93.78-.165.398-.143.854.107 1.204l.527.738c.32.447.269 1.06-.12 1.45l-.774.773a1.125 1.125 0 01-1.449.12l-.738-.527c-.35-.25-.806-.272-1.203-.107-.397.165-.71.505-.781.929l-.149.894c-.09.542-.56.94-1.11.94h-1.094c-.55 0-1.019-.398-1.11-.94l-.148-.894c-.071-.424-.384-.764-.781-.93-.398-.164-.854-.142-1.204.108l-.738.527c-.447.32-1.06.269-1.45-.12l-.773-.774a1.125 1.125 0 01-.12-1.45l.527-.737c.25-.35.273-.806.108-1.204-.165-.397-.505-.71-.93-.78l-.894-.15c-.542-.09-.94-.56-.94-1.109v-1.094c0-.55.398-1.02.94-1.11l.894-.149c.424-.07.765-.383.93-.78.165-.398.143-.854-.107-1.204l-.527-.738a1.125 1.125 0 01.12-1.45l.773-.773a1.125 1.125 0 011.45-.12l.737.527c.35.25.807.272 1.204.107.397-.165.71-.505.78-.929l.15-.894z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>설정</span>
          </a>
        </div>
      </nav>
    <% end %>

    <!-- ═══ MODAL (Turbo Frame) ═══ -->
    <turbo-frame id="modal"></turbo-frame>
  </body>
</html>
