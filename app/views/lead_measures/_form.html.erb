<%= form_with(model: [wig, lead_measure], class: "space-y-5") do |f| %>
  <% if lead_measure.errors.any? %>
    <div class="bg-rose-500/10 border border-rose-500/20 text-rose-400 text-sm px-4 py-3 rounded-xl">
      <% lead_measure.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <label class="block text-xs font-semibold text-[#8896b3] uppercase tracking-wider mb-2">선행지표 이름</label>
    <%= f.text_field :title, required: true, placeholder: "예: 신규 미팅 건수",
        class: "w-full h-12 px-4 bg-[#111a2e] border border-[#1e2d4a] rounded-xl text-white placeholder-[#5d6d8e] focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors" %>
  </div>

  <%= f.hidden_field :weekly_target, value: lead_measure.weekly_target || 1 %>
  <%= f.hidden_field :week_start_date, value: lead_measure.week_start_date || Date.current.beginning_of_week(:monday) %>

  <div class="flex gap-3 pt-2">
    <%= f.submit lead_measure.new_record? ? "추가" : "수정 완료",
        class: "flex-1 h-12 bg-gradient-to-r from-indigo-500 to-violet-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-500/25 active:scale-[0.98] transition-all cursor-pointer" %>
    <a href="<%= root_path %>" class="h-12 px-5 flex items-center justify-center text-sm font-semibold text-[#8896b3] hover:text-[#c5cfe0] border border-[#1e2d4a] rounded-xl transition-colors">
      취소
    </a>
  </div>
<% end %>
