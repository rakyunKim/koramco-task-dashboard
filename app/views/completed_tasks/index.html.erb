<div class="animate-fade-in-up">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl lg:text-2xl font-extrabold">완료 내역</h1>
    <% if @members.any? %>
      <div class="relative">
        <%= form_tag completed_tasks_path, method: :get, class: "flex items-center gap-2" do %>
          <%= select_tag :member_id,
              options_from_collection_for_select(@members, :id, :name, params[:member_id].to_i),
              prompt: "전체 멤버",
              onchange: "this.form.requestSubmit()",
              class: "h-9 pl-3 pr-8 bg-white border border-[#e2e6ed] rounded-xl text-[13px] text-[#1a202c] focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors appearance-none" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @weeks.empty? %>
    <div class="bg-white rounded-2xl border border-[#e2e6ed] p-12 text-center">
      <div class="w-12 h-12 rounded-full bg-[#f0f2f5] flex items-center justify-center mx-auto mb-3">
        <svg class="w-6 h-6 text-[#94a3b8]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <p class="text-sm text-[#64748b]">완료된 할 일이 없습니다</p>
    </div>
  <% else %>
    <div class="space-y-6">
      <%
        day_names = { 1 => "월", 2 => "화", 3 => "수", 4 => "목", 5 => "금", 6 => "토", 0 => "일" }
        current_monday = Date.current.beginning_of_week(:monday)
      %>
      <% @weeks.each do |week_start, days| %>
        <%
          week_label = week_start == current_monday ? "이번 주" : "#{week_start.strftime('%-m/%-d')} 주"
          total_count = days.values.flatten.size
        %>
        <div class="bg-white rounded-2xl border border-[#e2e6ed] overflow-hidden">
          <!-- Week header -->
          <div class="px-5 py-3 border-b border-[#e2e6ed] flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="text-sm font-extrabold text-[#1a202c]"><%= week_label %></span>
              <span class="text-xs text-[#94a3b8]"><%= week_start.strftime('%Y.%-m.%-d') %> ~ <%= (week_start + 6).strftime('%-m.%-d') %></span>
            </div>
            <span class="text-xs font-bold text-indigo-500 bg-indigo-50 px-2 py-0.5 rounded-md"><%= total_count %>개 완료</span>
          </div>

          <!-- Days -->
          <% days.sort_by { |date, _| date }.each do |date, tasks| %>
            <div class="border-b border-[#e2e6ed] last:border-b-0">
              <div class="px-5 py-2 bg-[#f8f9fb] flex items-center gap-2">
                <span class="text-xs font-bold text-[#64748b]"><%= date.strftime('%-m/%-d') %></span>
                <span class="text-xs font-bold text-[#94a3b8]">(<%= day_names[date.wday] %>)</span>
                <span class="text-[11px] text-[#cbd5e1]"><%= tasks.size %>개</span>
              </div>
              <div class="divide-y divide-[#e2e6ed]/50">
                <% tasks.each do |task| %>
                  <div class="flex items-center gap-3 px-5 py-3">
                    <div class="w-5 h-5 rounded-full bg-emerald-100 flex items-center justify-center shrink-0">
                      <svg class="w-3 h-3 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                      </svg>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="text-[15px] text-[#1a202c]">
                        <span class="text-[12px] font-semibold text-indigo-500/70">[<%= task.lead_measure&.title %>]</span>
                        <%= task.title %>
                        <% if task.jira_linked? %>
                          <a href="<%= task.jira_url %>" target="_blank" rel="noopener"
                             class="inline-flex items-center gap-1 ml-1 px-1.5 py-0.5 rounded bg-blue-50 text-blue-600 text-[11px] font-bold hover:bg-blue-100 transition-colors no-underline">
                            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M11.571 11.513H0a5.218 5.218 0 0 0 5.232 5.215h2.13v2.057A5.215 5.215 0 0 0 12.575 24V12.518a1.005 1.005 0 0 0-1.005-1.005zm5.723-5.756H5.736a5.215 5.215 0 0 0 5.215 5.214h2.129v2.058a5.218 5.218 0 0 0 5.215 5.214V6.758a1.001 1.001 0 0 0-1.001-1.001zM23.013 0H11.455a5.215 5.215 0 0 0 5.215 5.215h2.129v2.057A5.215 5.215 0 0 0 24 12.483V1.005A1.005 1.005 0 0 0 23.013 0z"/></svg>
                            <%= task.jira_issue_key %>
                          </a>
                        <% end %>
                      </div>
                    </div>
                    <div class="flex items-center gap-2 shrink-0">
                      <div class="flex items-center gap-1.5">
                        <div class="w-5 h-5 rounded-full bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center">
                          <span class="text-[9px] font-bold text-white"><%= task.member&.name&.first %></span>
                        </div>
                        <span class="text-[12px] text-[#94a3b8]"><%= task.member&.name %></span>
                      </div>
                      <span class="text-[11px] text-[#cbd5e1]"><%= task.completed_at.strftime('%H:%M') %></span>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
