<%= turbo_frame_tag task do %>
  <div class="flex items-center gap-3 py-3 group" data-controller="task-toggle" data-task-toggle-task-id-value="<%= task.id %>">
    <input type="checkbox"
           class="task-checkbox"
           <%= "checked" if task.completed? %>
           data-action="change->task-toggle#toggle">
    <div class="flex-1 min-w-0">
      <span class="text-[15px] leading-snug <%= task.completed? ? 'line-through text-[#94a3b8]' : 'text-[#1a202c]' %> transition-colors">
        <span class="text-[12px] font-semibold <%= task.completed? ? 'text-[#cbd5e1]' : 'text-indigo-500/70' %>">[<%= task.lead_measure.title %>]</span>
        <%= task.title %>
        <% if task.jira_linked? %>
          <a href="<%= task.jira_url %>" target="_blank" rel="noopener" class="inline-flex items-center gap-1 ml-1 px-1.5 py-0.5 rounded bg-blue-50 text-blue-600 text-[11px] font-bold hover:bg-blue-100 transition-colors no-underline" onclick="event.stopPropagation()">
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M11.571 11.513H0a5.218 5.218 0 0 0 5.232 5.215h2.13v2.057A5.215 5.215 0 0 0 12.575 24V12.518a1.005 1.005 0 0 0-1.005-1.005zm5.723-5.756H5.736a5.215 5.215 0 0 0 5.215 5.214h2.129v2.058a5.218 5.218 0 0 0 5.215 5.214V6.758a1.001 1.001 0 0 0-1.001-1.001zM23.013 0H11.455a5.215 5.215 0 0 0 5.215 5.215h2.129v2.057A5.215 5.215 0 0 0 24 12.483V1.005A1.005 1.005 0 0 0 23.013 0z"/></svg>
            <%= task.jira_issue_key %>
          </a>
        <% end %>
      </span>
    </div>
    <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
      <a href="<%= edit_lead_measure_task_path(task.lead_measure, task) %>" data-turbo-frame="_top" class="text-[#94a3b8] hover:text-[#64748b] p-1.5">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
        </svg>
      </a>
    </div>
  </div>
<% end %>
